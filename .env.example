# ==========================================
# Influencia Platform - Environment Variables
# ==========================================
# Copy this file to .env.production and fill in your actual values
# Never commit .env.production to version control!

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Get from: Neon.tech, Supabase, or Railway
# Example: postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ==========================================
# REDIS CONFIGURATION
# ==========================================
# Get from: Upstash.com or Redis Cloud
# For production, always use password and TLS
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_USERNAME=default
REDIS_TLS=true
REDIS_URL=redis://default:password@host:6379

# Session configuration
SESSION_TTL=604800
MAX_SESSIONS_PER_USER=5

# ==========================================
# JWT & SECURITY
# ==========================================
# Generate with: openssl rand -base64 32 (or use Node.js crypto)
# Must be at least 32 characters for production!
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-here
JWT_EXPIRES_IN=7d

# ==========================================
# BACKEND API CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=3000

# CORS - Set to your actual domain(s) in production
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# AI SERVICE CONFIGURATION
# ==========================================
# Internal Docker URL (don't change this for Docker deployments)
AI_SERVICE_URL=http://ai:5001

# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio

# Enable/disable LLM features (true/false)
USE_LLM=true

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Update these with your actual deployed URLs
# For local Docker: http://localhost:3000/v1
# For production: https://api.yourdomain.com/v1
VITE_API_URL=https://api.yourdomain.com/v1
VITE_AI_API_URL=https://ai.yourdomain.com

# ===========================================
# SOCIAL MEDIA API KEYS (Optional)
# ===========================================
# Instagram/Facebook
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
VITE_API_URL=https://api.yourdomain.com/v1
VITE_AI_API_URL=https://ai.yourdomain.com

# ===========================================
# MONITORING (Optional)
# ===========================================
SENTRY_DSN=
LOG_LEVEL=info
